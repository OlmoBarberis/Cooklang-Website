---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Una raccolta di ricette', image } = Astro.props;
const siteName = 'Le mie ricette';
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <title>{title === siteName ? siteName : `${title} · ${siteName}`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-title">Le mie ricette</a>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Fatto con <span aria-label="amore">♥</span> da <a href="https://github.com/OlmoBarberis" target="_blank" rel="noopener">Olmo</a> · <a href="https://cooklang.org" target="_blank" rel="noopener">Cooklang</a></p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg:          #FFFFFF;
    --color-surface:     #FFFFFF;
    --color-surface-alt: #F5F5F5;
    --color-border:      #E0E0E0;
    --color-border-strong: #111111;
    --color-text:        #0A0A0A;
    --color-muted:       #6B6B6B;
    --color-accent:      #D4622A;
    --color-accent-dk:   #B3501F;
    --color-tag-bg:      #F0F0F0;
    --color-tag-text:    #3A3A3A;

    --color-ingredient: #D4622A;
    --color-cookware:   #3A6EA6;
    --color-timer:      #2E8B57;

    --font-sans: 'Inter', system-ui, sans-serif;
    --font-serif: 'Inter', system-ui, sans-serif;

    --radius-sm: 2px;
    --radius-md: 2px;
    --radius-lg: 2px;

    --shadow-card: none;
    --shadow-card-hover: none;

    --max-width: 1280px;
    --content-width: 760px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    -webkit-text-size-adjust: 100%;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  main { flex: 1; }

  img { display: block; max-width: 100%; }

  a { color: inherit; text-decoration: none; }
  a:hover { color: var(--color-accent); }

  /* ── Header ── */
  .site-header {
    padding: 1.25rem 1.5rem;
    border-bottom: 2px solid var(--color-border-strong);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .site-title {
    font-size: 0.875rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .site-title:hover { color: var(--color-accent); }

  /* ── Footer ── */
  .site-footer {
    padding: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    text-transform: uppercase;
  }
  .site-footer a { color: var(--color-muted); }
  .site-footer a:hover { color: var(--color-accent); }

  /* ── Tag pills ── */
  .tag {
    display: inline-block;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25em 0.6em;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    line-height: 1.8;
    transition: background 0.1s, color 0.1s;
  }
  a.tag:hover {
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
  }

  /* ── Inline recipe tokens ── */
  .token-ingredient {
    color: var(--color-ingredient);
    font-weight: 600;
  }
  .token-cookware {
    color: var(--color-cookware);
    font-style: italic;
  }
  .token-timer {
    color: var(--color-timer);
    font-weight: 600;
    white-space: nowrap;
  }
  .token-timer::before { content: '⏱ '; }

  /* ── Step notes ── */
  .step-note {
    border-left: 3px solid var(--color-accent);
    padding: 0.5rem 1rem;
    margin: 0.5rem 0;
    color: var(--color-muted);
    font-style: italic;
    background: var(--color-surface-alt);
  }
</style>
