---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Una raccolta di ricette', image } = Astro.props;
const siteName = 'Le mie ricette';
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <title>{title === siteName ? siteName : `${title} · ${siteName}`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:ital,wght@0,300;0,400;0,700;1,300;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-title">{siteName}</a>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Fatto con <span aria-label="amore">♥</span> e <a href="https://cooklang.org" target="_blank" rel="noopener">Cooklang</a></p>
    </footer>
  </body>
</html>

<style is:global>
  /* ── Design tokens ── */
  :root {
    --color-bg:        #FAF7F2;
    --color-surface:   #FFFFFF;
    --color-border:    #E8DDD0;
    --color-text:      #1C1208;
    --color-muted:     #7A6855;
    --color-accent:    #C4622D;
    --color-accent-dk: #9B4A1F;
    --color-tag-bg:    #F2EAE0;
    --color-tag-text:  #7A4A28;

    --color-ingredient: #C4622D;
    --color-cookware:   #5B7FA6;
    --color-timer:      #4A8C6A;

    --font-serif: 'Playfair Display', Georgia, serif;
    --font-sans:  'Lato', system-ui, sans-serif;

    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 16px;

    --shadow-card: 0 2px 8px rgba(44, 24, 8, 0.08);
    --shadow-card-hover: 0 6px 24px rgba(44, 24, 8, 0.14);

    --max-width: 1200px;
    --content-width: 720px;
  }

  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    -webkit-text-size-adjust: 100%;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  main { flex: 1; }

  img { display: block; max-width: 100%; }

  a { color: var(--color-accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ── Site header ── */
  .site-header {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .site-title {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 4vw, 1.75rem);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .site-title:hover { text-decoration: none; color: var(--color-accent); }

  /* ── Site footer ── */
  .site-footer {
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-muted);
  }
  .site-footer a { color: var(--color-muted); }
  .site-footer a:hover { color: var(--color-accent); }

  /* ── Tag pills ── */
  .tag {
    display: inline-block;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.2em 0.65em;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    line-height: 1.8;
    transition: background 0.15s;
  }
  a.tag:hover {
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
  }

  /* ── Inline recipe tokens ── */
  .token-ingredient {
    color: var(--color-ingredient);
    font-weight: 600;
  }
  .token-cookware {
    color: var(--color-cookware);
    font-style: italic;
  }
  .token-timer {
    color: var(--color-timer);
    font-weight: 600;
    white-space: nowrap;
  }
  .token-timer::before { content: '⏱ '; font-style: normal; }

  /* ── Blockquote / note steps ── */
  .step-note {
    border-left: 3px solid var(--color-accent);
    padding: 0.5rem 1rem;
    margin: 0.75rem 0;
    color: var(--color-muted);
    font-style: italic;
    background: var(--color-tag-bg);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
</style>
