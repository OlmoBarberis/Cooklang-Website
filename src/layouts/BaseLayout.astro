---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Una raccolta di ricette', image } = Astro.props;
const siteName = 'Le mie ricette';
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <title>{title === siteName ? siteName : `${title} · ${siteName}`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-title">{siteName}</a>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Fatto con <span aria-label="amore">♥</span> da <a href="https://github.com/OlmoBarberis" target="_blank" rel="noopener">Olmo</a> con <a href="https://cooklang.org" target="_blank" rel="noopener">Cooklang</a></p>
    </footer>
  </body>
</html>

<style is:global>
  /* ── Design tokens: light ── */
  :root {
    --color-bg:        #F6F6F5;
    --color-surface:   #FFFFFF;
    --color-border:    #E3E2DF;
    --color-text:      #1A1A18;
    --color-muted:     #888680;
    --color-accent:    #D4622A;
    --color-accent-dk: #B3501F;
    --color-tag-bg:    #ECEAE7;
    --color-tag-text:  #6B5A4A;

    --color-ingredient: #D4622A;
    --color-cookware:   #4A7FA6;
    --color-timer:      #3A8C5E;

    --header-blur-bg: rgba(246, 246, 245, 0.88);

    --font-serif: 'DM Serif Display', Georgia, serif;
    --font-sans:  'Inter', system-ui, sans-serif;

    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;

    --shadow-card: none;
    --shadow-card-hover: 0 8px 32px rgba(24, 22, 15, 0.12);

    --max-width: 1200px;
    --content-width: 720px;
  }

  /* ── Design tokens: dark ── */
  @media (prefers-color-scheme: dark) {
    :root {
      --color-bg:        #111110;
      --color-surface:   #1C1B19;
      --color-border:    #2E2C28;
      --color-text:      #F0EDE8;
      --color-muted:     #7A7268;
      --color-accent:    #E8784A;
      --color-accent-dk: #D4622A;
      --color-tag-bg:    #252320;
      --color-tag-text:  #D4A98A;

      --color-ingredient: #E8784A;
      --color-cookware:   #6A9FBF;
      --color-timer:      #5AAF7A;

      --header-blur-bg: rgba(17, 17, 16, 0.88);

      --shadow-card: 0 2px 16px rgba(0, 0, 0, 0.4);
      --shadow-card-hover: 0 8px 40px rgba(0, 0, 0, 0.6);
    }
  }

  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    -webkit-text-size-adjust: 100%;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  main { flex: 1; }

  img { display: block; max-width: 100%; }

  a { color: var(--color-accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ── Site header ── */
  .site-header {
    padding: 1rem 1.5rem;
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background 0.25s, backdrop-filter 0.25s, box-shadow 0.25s;
  }

  .site-header.scrolled {
    background: var(--header-blur-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 1px 0 var(--color-border);
  }

  .site-title {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 4vw, 1.6rem);
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .site-title:hover { text-decoration: none; color: var(--color-accent); }

  /* ── Site footer ── */
  .site-footer {
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .site-footer a { color: var(--color-muted); }
  .site-footer a:hover { color: var(--color-accent); }

  /* ── Tag pills ── */
  .tag {
    display: inline-block;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.2em 0.6em;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    line-height: 1.8;
    transition: background 0.15s, color 0.15s;
  }
  a.tag:hover {
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
  }

  /* ── Inline recipe tokens ── */
  .token-ingredient {
    color: var(--color-ingredient);
    font-weight: 600;
  }
  .token-cookware {
    color: var(--color-cookware);
    font-style: italic;
  }
  .token-timer {
    color: var(--color-timer);
    font-weight: 600;
    white-space: nowrap;
  }
  .token-timer::before { content: '⏱ '; font-style: normal; }

  /* ── Blockquote / note steps ── */
  .step-note {
    border-left: 3px solid var(--color-accent);
    padding: 0.5rem 1rem;
    margin: 0.75rem 0;
    color: var(--color-muted);
    font-style: italic;
    background: var(--color-tag-bg);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
</style>

<script>
  const header = document.querySelector('.site-header');
  if (header) {
    const toggle = () => header.classList.toggle('scrolled', window.scrollY > 8);
    toggle();
    window.addEventListener('scroll', toggle, { passive: true });
  }
</script>
