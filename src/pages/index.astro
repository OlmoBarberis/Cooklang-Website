---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getAllRecipes } from '../lib/recipes';

const recipes = getAllRecipes();

function normalize(s: string) {
  return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
}

const summaries = recipes.map((r) => ({
  slug: r.slug,
  title: r.title,
  tags: r.tags,
  image: r.image,
  category: r.category,
  ingredientCount: r.ingredients.length,
  searchText: normalize(r.title),
}));

const grouped: Record<string, typeof summaries> = {};
for (const r of summaries) {
  const letter = r.title[0].toUpperCase();
  if (!grouped[letter]) grouped[letter] = [];
  grouped[letter].push(r);
}
const letters = Object.keys(grouped).sort((a, b) => a.localeCompare(b, 'it'));
---

<BaseLayout title="Le mie ricette">
  <div class="page-wrap">

    <div class="filter-bar">
      <input
        type="search"
        id="recipe-search"
        class="search-input"
        placeholder="Cerca ricette…"
        aria-label="Cerca ricette"
        autocomplete="off"
      />
      <div class="alpha-nav-scroll">
        <nav class="alpha-nav" aria-label="Salta alla lettera">
          {letters.map((l) => (
            <button class="alpha-btn" data-letter={l}>{l}</button>
          ))}
        </nav>
      </div>
    </div>

    <p class="count" id="recipe-count">{summaries.length} ricette</p>

    {letters.map((letter) => (
      <section class="letter-section" id={`letter-${letter}`}>
        <h2 class="letter-heading">{letter}</h2>
        <div class="recipe-grid">
          {grouped[letter].map((r) => (
            <div class="card-wrap" data-search={r.searchText}>
              <RecipeCard recipe={r} />
            </div>
          ))}
        </div>
      </section>
    ))}

    <p class="empty-state" id="empty-state" hidden>Nessuna ricetta trovata.</p>

  </div>
</BaseLayout>

<style>
  .page-wrap {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem 4rem;
  }

  /* ── Filter bar ── */
  .filter-bar {
    position: sticky;
    top: 4rem; /* fallback; JS sets exact header height */
    z-index: 90;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 4px 12px rgba(44, 24, 8, 0.06);
    padding: 1.25rem 0 1.25rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .search-input {
    width: 100%;
    padding: 0.65rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    background: var(--color-surface);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s;
  }
  .search-input:focus { border-color: var(--color-accent); }
  .search-input::placeholder { color: var(--color-muted); }

  /* ── Alphabet nav — scrollable wrapper, centered inner ── */
  .alpha-nav-scroll {
    overflow-x: auto;
    scrollbar-width: none;
  }
  .alpha-nav-scroll::-webkit-scrollbar { display: none; }

  .alpha-nav {
    display: flex;
    gap: 0.3rem;
    width: max-content;
    margin: 0 auto;
  }

  .alpha-btn {
    flex-shrink: 0;
    font-size: 0.78rem;
    font-weight: 700;
    width: 2rem;
    height: 2rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s, opacity 0.15s;
    line-height: 1;
  }
  .alpha-btn:hover:not(.alpha-disabled) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .alpha-btn.alpha-active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .alpha-btn.alpha-disabled {
    opacity: 0.25;
    cursor: default;
  }

  /* ── Count ── */
  .count {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 2rem;
  }

  /* ── Letter sections ── */
  .letter-section {
    margin-bottom: 3rem;
    scroll-margin-top: 14rem; /* fallback; JS overrides with exact value */
  }

  .letter-heading {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-border);
  }

  /* ── Recipe grid ── */
  .recipe-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .card-wrap {
    display: flex;
    flex-direction: column;
  }
  .card-wrap[hidden] { display: none; }
  .card-wrap :global(.card) { flex: 1; }

  /* ── Empty state ── */
  .empty-state {
    text-align: center;
    padding: 3rem 0;
    color: var(--color-muted);
  }

  /* ── Responsive ── */
  @media (min-width: 480px) {
    .recipe-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 640px) {
    .recipe-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1024px) {
    .page-wrap { padding: 0 2rem 5rem; }
    .recipe-grid { grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
    /* scroll-margin-top handled by JS */
  }
</style>

<script>
  function normalize(s: string) {
    return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  }

  // Pin filter bar exactly below the site header, whatever its actual height is
  const header = document.querySelector<HTMLElement>('.site-header');
  const filterBar = document.querySelector<HTMLElement>('.filter-bar');
  if (header && filterBar) {
    const pin = () => {
      const h = header.offsetHeight;
      filterBar.style.top = h + 'px';
      const barH = filterBar.offsetHeight;
      sections.forEach((s) => {
        s.style.scrollMarginTop = (h + barH + 16) + 'px';
      });
    };
    pin();
    new ResizeObserver(pin).observe(header);
    new ResizeObserver(pin).observe(filterBar);
  }

  const searchInput = document.getElementById('recipe-search') as HTMLInputElement;
  const countEl = document.getElementById('recipe-count')!;
  const emptyState = document.getElementById('empty-state') as HTMLElement;
  const sections = Array.from(document.querySelectorAll<HTMLElement>('.letter-section'));
  const alphaBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.alpha-btn'));

  function applyFilter(query: string) {
    const q = normalize(query);
    let total = 0;

    for (const section of sections) {
      const cards = Array.from(section.querySelectorAll<HTMLElement>('.card-wrap'));
      let count = 0;

      for (const card of cards) {
        const match = !q || (card.dataset.search ?? '').includes(q);
        card.hidden = !match;
        if (match) count++;
      }

      section.hidden = count === 0;
      total += count;

      const letter = section.id.slice('letter-'.length);
      alphaBtns
        .find((b) => b.dataset.letter === letter)
        ?.classList.toggle('alpha-disabled', count === 0);
    }

    countEl.textContent = `${total} ricett${total === 1 ? 'a' : 'e'}`;
    emptyState.hidden = total > 0;
  }

  searchInput.addEventListener('input', (e) =>
    applyFilter((e.target as HTMLInputElement).value)
  );

  for (const btn of alphaBtns) {
    btn.addEventListener('click', () => {
      const letter = btn.dataset.letter!;
      const section = document.getElementById(`letter-${letter}`);
      if (!section || section.hidden) return;

      section.scrollIntoView({ behavior: 'smooth', block: 'start' });

      alphaBtns.forEach((b) => b.classList.remove('alpha-active'));
      btn.classList.add('alpha-active');
      setTimeout(() => btn.classList.remove('alpha-active'), 1200);
    });
  }
</script>
