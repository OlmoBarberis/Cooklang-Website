---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getAllRecipes, getAllTags } from '../lib/recipes';

const recipes = getAllRecipes();
const allTags = getAllTags();

const summaries = recipes.map((r) => ({
  slug: r.slug,
  title: r.title,
  tags: r.tags,
  image: r.image,
  category: r.category,
  ingredientCount: r.ingredients.length,
}));

const grouped: Record<string, typeof summaries> = {};
for (const r of summaries) {
  const letter = r.title[0].toUpperCase();
  if (!grouped[letter]) grouped[letter] = [];
  grouped[letter].push(r);
}
const letters = Object.keys(grouped).sort((a, b) => a.localeCompare(b, 'it'));
---

<BaseLayout title="Le mie ricette">
  <div class="page-wrap">

    <div class="filter-bar">
      <!-- Alphabet nav -->
      <div class="alpha-nav-scroll">
        <nav class="alpha-nav" aria-label="Salta alla lettera">
          {letters.map((l) => (
            <button class="alpha-btn" data-letter={l}>{l}</button>
          ))}
        </nav>
      </div>

      <!-- Tag filters -->
      <div class="tag-nav-scroll">
        <div class="tag-nav" role="group" aria-label="Filtra per categoria">
          <button class="tag-filter tag-filter-all tag-active" data-tag="">Tutte</button>
          {allTags.map((tag) => (
            <button class="tag-filter" data-tag={tag}>{tag}</button>
          ))}
        </div>
      </div>
    </div>

    <p class="count" id="recipe-count">{summaries.length} ricette</p>

    {letters.map((letter) => (
      <section class="letter-section" id={`letter-${letter}`}>
        <h2 class="letter-heading">{letter}</h2>
        <div class="recipe-grid">
          {grouped[letter].map((r) => (
            <div
              class="card-wrap"
              data-tags={r.tags.join(',')}
            >
              <RecipeCard recipe={r} />
            </div>
          ))}
        </div>
      </section>
    ))}

    <p class="empty-state" id="empty-state" hidden>Nessuna ricetta trovata.</p>

  </div>
</BaseLayout>

<style>
  .page-wrap {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem 4rem;
  }

  /* ── Filter bar ── */
  .filter-bar {
    position: sticky;
    top: 4rem;
    z-index: 90;
    background: var(--color-bg);
    /* break out of .page-wrap's padding */
    margin-left: -1rem;
    margin-right: -1rem;
    padding: 1rem 1rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ── Alphabet nav ── */
  .alpha-nav-scroll {
    overflow-x: auto;
    scrollbar-width: none;
  }
  .alpha-nav-scroll::-webkit-scrollbar { display: none; }

  .alpha-nav {
    display: flex;
    gap: 0.2rem;
    width: max-content;
    margin: 0 auto;
  }

  .alpha-btn {
    flex-shrink: 0;
    font-family: var(--font-serif);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
    border: none;
    border-radius: 100px;
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, opacity 0.15s;
    line-height: 1.6;
  }
  .alpha-btn:hover:not(.alpha-disabled) {
    background: var(--color-tag-bg);
    color: var(--color-accent);
  }
  .alpha-btn.alpha-active {
    background: var(--color-accent);
    color: #fff;
  }
  .alpha-btn.alpha-disabled {
    opacity: 0.2;
    cursor: default;
  }

  /* ── Tag filter row ── */
  .tag-nav-scroll {
    /* no scroll — tags wrap */
  }

  .tag-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag-filter {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.85rem;
    border: 1.5px solid var(--color-border);
    border-radius: 100px;
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .tag-filter:hover:not(.tag-active) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .tag-filter.tag-active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  /* ── Count ── */
  .count {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 2rem;
  }

  /* ── Letter sections ── */
  .letter-section {
    margin-bottom: 3rem;
    scroll-margin-top: 14rem;
  }

  .letter-heading {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-border);
  }

  /* ── Recipe grid ── */
  .recipe-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .card-wrap {
    display: flex;
    flex-direction: column;
  }
  .card-wrap[hidden] { display: none; }
  .card-wrap :global(.card) { flex: 1; }

  /* ── Empty state ── */
  .empty-state {
    text-align: center;
    padding: 3rem 0;
    color: var(--color-muted);
  }

  /* ── Responsive ── */
  @media (min-width: 480px) {
    .recipe-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 640px) {
    .recipe-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .page-wrap { padding: 0 2rem 5rem; }
    .filter-bar { margin-left: -2rem; margin-right: -2rem; padding-left: 2rem; padding-right: 2rem; }
    .recipe-grid { grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  }
</style>

<script>
  // Pin filter bar exactly below site header
  const header = document.querySelector<HTMLElement>('.site-header');
  const filterBar = document.querySelector<HTMLElement>('.filter-bar');
  const sections = Array.from(document.querySelectorAll<HTMLElement>('.letter-section'));

  if (header && filterBar) {
    const pin = () => {
      const h = header.offsetHeight;
      filterBar.style.top = h + 'px';
      const barH = filterBar.offsetHeight;
      sections.forEach((s) => {
        s.style.scrollMarginTop = (h + barH + 16) + 'px';
      });
    };
    pin();
    new ResizeObserver(pin).observe(header);
    new ResizeObserver(pin).observe(filterBar);
  }

  const countEl = document.getElementById('recipe-count')!;
  const emptyState = document.getElementById('empty-state') as HTMLElement;
  const alphaBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.alpha-btn'));
  const tagBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.tag-filter'));

  let activeTag = '';

  function applyFilter() {
    let total = 0;

    for (const section of sections) {
      const cards = Array.from(section.querySelectorAll<HTMLElement>('.card-wrap'));
      let count = 0;

      for (const card of cards) {
        const tags = (card.dataset.tags ?? '').split(',').filter(Boolean);
        const match = !activeTag || tags.includes(activeTag);
        card.hidden = !match;
        if (match) count++;
      }

      section.hidden = count === 0;
      total += count;

      const letter = section.id.slice('letter-'.length);
      alphaBtns
        .find((b) => b.dataset.letter === letter)
        ?.classList.toggle('alpha-disabled', count === 0);
    }

    countEl.textContent = `${total} ricett${total === 1 ? 'a' : 'e'}`;
    emptyState.hidden = total > 0;
  }

  // Tag filter clicks
  for (const btn of tagBtns) {
    btn.addEventListener('click', () => {
      activeTag = btn.dataset.tag ?? '';
      tagBtns.forEach((b) => b.classList.remove('tag-active'));
      btn.classList.add('tag-active');
      applyFilter();
    });
  }

  // Alphabet jump
  for (const btn of alphaBtns) {
    btn.addEventListener('click', () => {
      const letter = btn.dataset.letter!;
      const section = document.getElementById(`letter-${letter}`);
      if (!section || section.hidden) return;

      section.scrollIntoView({ behavior: 'smooth', block: 'start' });

      alphaBtns.forEach((b) => b.classList.remove('alpha-active'));
      btn.classList.add('alpha-active');
      setTimeout(() => btn.classList.remove('alpha-active'), 1200);
    });
  }
</script>
