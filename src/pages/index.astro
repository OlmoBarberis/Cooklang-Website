---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getAllRecipes, getAllTags } from '../lib/recipes';

const recipes = getAllRecipes();
const allTags = getAllTags();

const summaries = recipes.map((r) => ({
  slug: r.slug,
  title: r.title,
  tags: r.tags,
  image: r.image,
  category: r.category,
  ingredientCount: r.ingredients.length,
}));

const grouped: Record<string, typeof summaries> = {};
for (const r of summaries) {
  const letter = r.title[0].toUpperCase();
  if (!grouped[letter]) grouped[letter] = [];
  grouped[letter].push(r);
}
const letters = Object.keys(grouped).sort((a, b) => a.localeCompare(b, 'it'));
---

<BaseLayout title="Le mie ricette">

  <div class="filter-bar">
    <div class="filter-inner">
      <!-- Alphabet -->
      <nav class="alpha-nav" aria-label="Salta alla lettera">
        {letters.map((l) => (
          <button class="alpha-btn" data-letter={l}>{l}</button>
        ))}
      </nav>
      <!-- Tags -->
      <div class="tag-nav" role="group" aria-label="Filtra per categoria">
        <button class="tag-btn tag-active" data-tag="">Tutte</button>
        {allTags.map((tag) => (
          <button class="tag-btn" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </div>
  </div>

  <div class="page-wrap">

    <p class="count" id="recipe-count">{summaries.length} ricette</p>

    {letters.map((letter) => (
      <section class="letter-section" id={`letter-${letter}`}>
        <div class="letter-header">
          <span class="letter-glyph" aria-hidden="true">{letter}</span>
          <div class="letter-rule" />
        </div>
        <div class="recipe-grid">
          {grouped[letter].map((r) => (
            <div class="card-wrap" data-tags={r.tags.join(',')}>
              <RecipeCard recipe={r} />
            </div>
          ))}
        </div>
      </section>
    ))}

    <p class="empty-state" id="empty-state" hidden>Nessuna ricetta trovata.</p>

  </div>
</BaseLayout>

<style>
  /* ── Filter bar ── */
  .filter-bar {
    position: sticky;
    top: 0;
    z-index: 90;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .filter-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
  }

  /* ── Alphabet nav ── */
  .alpha-nav {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    border-bottom: 1px solid var(--color-border);
    padding: 0.5rem 0;
  }
  .alpha-nav::-webkit-scrollbar { display: none; }

  .alpha-btn {
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.5rem;
    border: none;
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition: color 0.1s;
    line-height: 1;
    text-transform: uppercase;
  }
  .alpha-btn:hover:not(.alpha-disabled) { color: var(--color-text); }
  .alpha-btn.alpha-active { color: var(--color-accent); }
  .alpha-btn.alpha-disabled { opacity: 0.2; cursor: default; }

  /* ── Tag filters ── */
  .tag-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    padding: 0.5rem 0;
  }

  .tag-btn {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border: none;
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition: color 0.1s, background 0.1s;
    white-space: nowrap;
    border-radius: var(--radius-sm);
  }
  .tag-btn:hover:not(.tag-active) {
    color: var(--color-text);
    background: var(--color-surface-alt);
  }
  .tag-btn.tag-active {
    background: var(--color-border-strong);
    color: #fff;
  }

  /* ── Page wrap ── */
  .page-wrap {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  /* ── Count ── */
  .count {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding: 1.5rem 0 0;
    margin-bottom: 2rem;
  }

  /* ── Letter sections ── */
  .letter-section {
    margin-bottom: 3.5rem;
    scroll-margin-top: 8rem;
  }

  .letter-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .letter-glyph {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    flex-shrink: 0;
  }

  .letter-rule {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  /* ── Recipe grid ── */
  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--color-border);
    border-left: 1px solid var(--color-border);
  }

  .card-wrap { display: flex; flex-direction: column; }
  .card-wrap[hidden] { display: none; }
  .card-wrap :global(.card) {
    flex: 1;
    border-top: none;
    border-left: none;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    border-radius: 0;
  }

  /* ── Empty state ── */
  .empty-state {
    text-align: center;
    padding: 4rem 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  /* ── Responsive ── */
  @media (min-width: 640px) {
    .recipe-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .recipe-grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (min-width: 1280px) {
    .recipe-grid { grid-template-columns: repeat(5, 1fr); }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('.site-header');
  const filterBar = document.querySelector<HTMLElement>('.filter-bar');
  const sections = Array.from(document.querySelectorAll<HTMLElement>('.letter-section'));

  if (header && filterBar) {
    const pin = () => {
      const h = header.offsetHeight;
      filterBar.style.top = h + 'px';
      const combined = h + filterBar.offsetHeight + 16;
      sections.forEach((s) => { s.style.scrollMarginTop = combined + 'px'; });
    };
    pin();
    new ResizeObserver(pin).observe(header);
    new ResizeObserver(pin).observe(filterBar);
  }

  const countEl = document.getElementById('recipe-count')!;
  const emptyState = document.getElementById('empty-state') as HTMLElement;
  const alphaBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.alpha-btn'));
  const tagBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.tag-btn'));

  let activeTag = '';

  function applyFilter() {
    let total = 0;
    for (const section of sections) {
      const cards = Array.from(section.querySelectorAll<HTMLElement>('.card-wrap'));
      let count = 0;
      for (const card of cards) {
        const tags = (card.dataset.tags ?? '').split(',').filter(Boolean);
        const match = !activeTag || tags.includes(activeTag);
        card.hidden = !match;
        if (match) count++;
      }
      section.hidden = count === 0;
      total += count;
      const letter = section.id.slice('letter-'.length);
      alphaBtns.find((b) => b.dataset.letter === letter)
        ?.classList.toggle('alpha-disabled', count === 0);
    }
    countEl.textContent = `${total} ricett${total === 1 ? 'a' : 'e'}`;
    emptyState.hidden = total > 0;
  }

  for (const btn of tagBtns) {
    btn.addEventListener('click', () => {
      activeTag = btn.dataset.tag ?? '';
      tagBtns.forEach((b) => b.classList.remove('tag-active'));
      btn.classList.add('tag-active');
      applyFilter();
    });
  }

  for (const btn of alphaBtns) {
    btn.addEventListener('click', () => {
      const section = document.getElementById(`letter-${btn.dataset.letter}`);
      if (!section || section.hidden) return;
      section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      alphaBtns.forEach((b) => b.classList.remove('alpha-active'));
      btn.classList.add('alpha-active');
      setTimeout(() => btn.classList.remove('alpha-active'), 1200);
    });
  }
</script>
