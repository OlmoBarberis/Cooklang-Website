---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getRecipesByTag } from '../../lib/recipes';

const { tag } = Astro.params;
const recipes = getRecipesByTag(tag ?? '');
if (recipes.length === 0) return new Response(null, { status: 404 });
const summaries = recipes.map((r) => ({
  slug: r.slug,
  title: r.title,
  tags: r.tags,
  image: r.image,
  category: r.category,
  ingredientCount: r.ingredients.length,
}));
---

<BaseLayout title={tag}>
  <div class="page-wrap">
    <a href="/" class="back-link">← Tutte le ricette</a>
    <h1 class="page-title">{tag}</h1>
    <p class="count">{recipes.length} {recipes.length === 1 ? 'ricetta' : 'ricette'}</p>

    <div class="recipe-grid">
      {summaries.map((r) => <RecipeCard recipe={r} />)}
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--color-accent); text-decoration: none; }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 400;
    margin-bottom: 0.4rem;
  }

  .count {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 1.75rem;
  }

  .recipe-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 480px) {
    .recipe-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 640px) {
    .recipe-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .page-wrap { padding: 2rem 2rem 5rem; }
    .recipe-grid { grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  }
</style>
