---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StepText from '../../components/StepText.astro';
import { getRecipeBySlug } from '../../lib/recipes';

const { slug } = Astro.params;
const recipe = getRecipeBySlug(slug);
if (!recipe) return new Response(null, { status: 404 });

const isExternalImage = recipe.image?.startsWith('http');
const imageSrc = recipe.image
  ? isExternalImage ? recipe.image : `/${recipe.image}`
  : null;

const hasIngredients = recipe.sidebarIngredients.length > 0;
const hasSections = recipe.sections.some((s) => s.content.length > 0);
---

<BaseLayout title={recipe.title} image={imageSrc ?? undefined}>

  {imageSrc && (
    <div class="hero">
      <img src={imageSrc} alt={recipe.title} />
    </div>
  )}

  <div class="recipe-wrap">

    <div class="recipe-header-row">
      <a href="/" class="back-link">← Ricette</a>
    </div>

    <header class="recipe-header">
      <div class="recipe-labels">
        {recipe.category && <span class="label">{recipe.category}</span>}
        {recipe.tags.map((tag) => (
          <a href={`/tag/${encodeURIComponent(tag)}`} class="label label-link">{tag}</a>
        ))}
      </div>
      <h1 class="recipe-title">{recipe.title}</h1>
      <div class="recipe-meta-row">
        {recipe.servings && (
          <span class="meta-chip">
            <span class="meta-key">Porzioni</span>
            <span class="meta-val">{recipe.servings}</span>
          </span>
        )}
        {recipe.source && (
          <span class="meta-chip">
            <span class="meta-key">Fonte</span>
            <span class="meta-val">
              {recipe.source.startsWith('http')
                ? <a href={recipe.source} target="_blank" rel="noopener">Link ↗</a>
                : recipe.source}
            </span>
          </span>
        )}
      </div>
    </header>

    <div class="recipe-body">

      {hasIngredients && (
        <aside class="ingredients-panel">
          <div class="panel-header">
            <span class="panel-title">Ingredienti</span>
          </div>

          <div class="multiplier-bar">
            <span class="mult-label">Dosi</span>
            <div class="mult-btns">
              {[0.5, 1, 2, 3].map((n) => (
                <button
                  class={`mult-btn${n === 1 ? ' active' : ''}`}
                  data-mult={n}
                  aria-pressed={n === 1 ? 'true' : 'false'}
                >
                  {n === 0.5 ? '½×' : `${n}×`}
                </button>
              ))}
              <input
                type="number"
                id="mult-input"
                class="mult-input"
                value="1"
                min="0.25"
                max="20"
                step="0.5"
                aria-label="Moltiplicatore personalizzato"
              />
            </div>
          </div>

          <ul class="ingredient-list">
            {recipe.sidebarIngredients.map((ing, i) => (
              <li class="ingredient-item">
                <label>
                  <input type="checkbox" class="ing-check" id={`ing-${i}`} />
                  <span class="ing-label">
                    {ing.displayText && (
                      <span
                        class="ing-qty"
                        data-base={typeof ing.quantity === 'number' ? ing.quantity : undefined}
                        data-unit={ing.unit ?? ''}
                      >{ing.displayText}</span>
                    )}
                    <span class="ing-name">{ing.name}</span>
                  </span>
                </label>
              </li>
            ))}
          </ul>
        </aside>
      )}

      {hasSections && (
        <div class="steps-panel">
          {recipe.sections.map((section) => (
            section.content.length > 0 && (
              <section class="recipe-section">
                {section.title && (
                  <h3 class="section-title">{section.title}</h3>
                )}
                <div class="section-content">
                  {section.content.map((item) => {
                    if (item.type === 'note') {
                      return <p class="step-note">{item.text}</p>;
                    }
                    return (
                      <div class="step-item">
                        <span class="step-num" aria-hidden="true">{item.step.number}</span>
                        <StepText
                          step={item.step}
                          ingredients={recipe.ingredients}
                          cookwares={recipe.cookwares}
                          timers={recipe.timers}
                          inlineQuantities={recipe.inlineQuantities}
                        />
                      </div>
                    );
                  })}
                </div>
              </section>
            )
          ))}
        </div>
      )}

    </div>
  </div>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    width: 100%;
    height: clamp(240px, 45vw, 520px);
    overflow: hidden;
    background: var(--color-surface-alt);
    border-bottom: 1px solid var(--color-border);
  }
  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Wrapper ── */
  .recipe-wrap {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem 5rem;
  }

  .recipe-header-row {
    padding: 1.25rem 0 0;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.25rem;
  }

  .back-link {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.1s;
  }
  .back-link:hover { color: var(--color-accent); }

  /* ── Header ── */
  .recipe-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .recipe-labels {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.875rem;
  }

  .label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-muted);
    background: var(--color-surface-alt);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-sm);
  }
  .label-link:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .recipe-title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .recipe-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .meta-chip {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .meta-key {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .meta-val {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .meta-val a { color: var(--color-accent); }

  /* ── Two-column layout ── */
  .recipe-body {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .recipe-body {
      flex-direction: row;
      align-items: flex-start;
      gap: 0;
    }
  }

  /* ── Ingredients ── */
  .ingredients-panel {
    flex: 0 0 220px;
  }

  @media (min-width: 768px) {
    .ingredients-panel {
      position: sticky;
      top: 7rem;
      border-right: 1px solid var(--color-border);
      padding-right: 2rem;
      margin-right: 2.5rem;
    }
  }

  .panel-header {
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-border-strong);
    margin-bottom: 1rem;
  }

  .panel-title {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  /* ── Multiplier ── */
  .multiplier-bar {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .mult-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .mult-btns {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .mult-btn {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.3em 0.6em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition: border-color 0.1s, color 0.1s, background 0.1s;
  }
  .mult-btn:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }
  .mult-btn.active {
    background: var(--color-border-strong);
    border-color: var(--color-border-strong);
    color: var(--color-bg);
  }

  .mult-input {
    width: 3.5rem;
    font-size: 0.75rem;
    font-family: var(--font-sans);
    font-weight: 600;
    padding: 0.3em 0.4em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
    text-align: center;
    -moz-appearance: textfield;
  }
  .mult-input::-webkit-outer-spin-button,
  .mult-input::-webkit-inner-spin-button { -webkit-appearance: none; }
  .mult-input:focus { outline: none; border-color: var(--color-border-strong); }

  /* ── Ingredient list ── */
  .ingredient-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .ingredient-item {
    border-bottom: 1px solid var(--color-border);
  }

  .ingredient-item label {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    cursor: pointer;
    padding: 0.5rem 0;
  }

  .ing-check {
    flex-shrink: 0;
    width: 0.875rem;
    height: 0.875rem;
    accent-color: var(--color-border-strong);
    cursor: pointer;
    margin-top: 0.15em;
  }

  .ing-label {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    font-size: 0.875rem;
    line-height: 1.4;
    transition: opacity 0.15s;
  }

  .ingredient-item:has(.ing-check:checked) .ing-label {
    opacity: 0.3;
    text-decoration: line-through;
  }

  .ing-qty {
    font-weight: 700;
    color: var(--color-text);
    white-space: nowrap;
  }
  .ing-name { color: var(--color-muted); }

  /* ── Steps ── */
  .steps-panel { flex: 1; min-width: 0; }

  .recipe-section { margin-bottom: 2.5rem; }

  .section-title {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .section-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step-item {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .step-item:first-child { border-top: 1px solid var(--color-border); }

  .step-num {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    line-height: 1.75;
    text-align: right;
  }
</style>

<script>
  const key = `checked:${window.location.pathname}`;
  const checks = document.querySelectorAll<HTMLInputElement>('.ing-check');
  const saved: string[] = JSON.parse(sessionStorage.getItem(key) ?? '[]');
  checks.forEach((el, i) => {
    if (saved.includes(String(i))) el.checked = true;
    el.addEventListener('change', () => {
      const active = [...checks]
        .map((c, idx) => (c.checked ? String(idx) : null))
        .filter(Boolean) as string[];
      sessionStorage.setItem(key, JSON.stringify(active));
    });
  });

  const qtyEls = document.querySelectorAll<HTMLElement>('[data-base]');
  const multBtns = document.querySelectorAll<HTMLButtonElement>('.mult-btn');
  const multInput = document.getElementById('mult-input') as HTMLInputElement | null;

  function formatQty(base: number, mult: number): string {
    return parseFloat((base * mult).toFixed(2)).toString();
  }

  function applyMultiplier(mult: number) {
    qtyEls.forEach((el) => {
      const base = parseFloat(el.dataset.base!);
      const unit = el.dataset.unit ?? '';
      el.textContent = unit ? `${formatQty(base, mult)} ${unit}` : formatQty(base, mult);
    });
  }

  function setActive(mult: number) {
    multBtns.forEach((btn) => {
      const match = parseFloat(btn.dataset.mult!) === mult;
      btn.classList.toggle('active', match);
      btn.setAttribute('aria-pressed', String(match));
    });
  }

  multBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const mult = parseFloat(btn.dataset.mult!);
      setActive(mult);
      if (multInput) multInput.value = String(mult);
      applyMultiplier(mult);
    });
  });

  multInput?.addEventListener('input', () => {
    const mult = parseFloat(multInput.value);
    if (!isNaN(mult) && mult > 0) { setActive(mult); applyMultiplier(mult); }
  });
</script>
