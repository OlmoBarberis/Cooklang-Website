---
import type { RecipeSummary } from '../lib/recipes';

interface Props {
  recipe: RecipeSummary;
}

const { recipe } = Astro.props;
const isExternalImage = recipe.image?.startsWith('http');
---

<a href={`/recipe/${recipe.slug}`} class="card">
  <div class="card-image">
    {recipe.image ? (
      <img
        src={isExternalImage ? recipe.image : `/${recipe.image}`}
        alt={recipe.title}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="card-placeholder" aria-hidden="true">
        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="placeholder-icon">
          <!-- Fork -->
          <line x1="20" y1="14" x2="20" y2="28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="16" y1="14" x2="16" y2="22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="24" y1="14" x2="24" y2="22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M16 22 Q20 26 24 22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
          <line x1="20" y1="28" x2="20" y2="50" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <!-- Knife -->
          <path d="M44 14 C44 14 48 20 48 28" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
          <line x1="48" y1="28" x2="44" y2="28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="44" y1="28" x2="44" y2="50" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
    )}
  </div>
  <div class="card-body">
    {(recipe.category || recipe.tags.length > 0) && (
      <p class="card-meta">
        {recipe.category && <span>{recipe.category}</span>}
        {recipe.category && recipe.tags.length > 0 && <span class="sep">·</span>}
        {recipe.tags.slice(0, 2).map((tag, i) => (
          <>
            {i > 0 && <span class="sep">·</span>}
            <span>{tag}</span>
          </>
        ))}
      </p>
    )}
    <h2 class="card-title">{recipe.title}</h2>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .card:hover {
    border-color: var(--color-border-strong);
    text-decoration: none;
  }
  .card:hover .card-image img {
    transform: scale(1.04);
  }

  .card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-surface-alt);
    border-bottom: 1px solid var(--color-border);
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface-alt);
    color: var(--color-border);
  }

  .placeholder-icon {
    width: 48px;
    height: 48px;
  }

  .card-body {
    padding: 0.75rem 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .card-meta {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    align-items: center;
  }
  .sep { color: var(--color-border); }

  .card-title {
    font-size: clamp(0.9rem, 2vw, 1rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
</style>
