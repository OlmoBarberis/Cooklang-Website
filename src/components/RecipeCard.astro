---
import type { RecipeSummary } from '../lib/recipes';

interface Props {
  recipe: RecipeSummary;
}

const { recipe } = Astro.props;
const isExternalImage = recipe.image?.startsWith('http');
---

<a href={`/recipe/${recipe.slug}`} class="card">
  <div class="card-image">
    {recipe.image ? (
      <img
        src={isExternalImage ? recipe.image : `/${recipe.image}`}
        alt={recipe.title}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="card-placeholder" aria-hidden="true">🍽</div>
    )}
  </div>
  <div class="card-body">
    {recipe.category && (
      <span class="card-category">{recipe.category}</span>
    )}
    <h2 class="card-title">{recipe.title}</h2>
    {recipe.tags.length > 0 && (
      <div class="card-tags">
        {recipe.tags.slice(0, 3).map((tag) => (
          <span class="card-tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
    color: var(--color-text);
    text-decoration: none;
  }
  .card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-3px);
    border-color: transparent;
    text-decoration: none;
  }

  .card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-tag-bg);
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    opacity: 0.3;
  }

  .card-body {
    padding: 0.875rem 1rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .card-category {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.2rem;
  }

  .card-tag {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .card-tag + .card-tag::before {
    content: '·';
    margin-right: 0.35rem;
    color: var(--color-border);
  }
</style>
